{
  "manifest_version": 3,
  "name": "书签导航",
  "description": "本地运行的新标签页书签导航扩展。",
  "version": "0.3.1",
  "icons": {
    "16": "icons/extension-16.png",
    "32": "icons/extension-32.png",
    "48": "icons/extension-48.png",
    "128": "icons/extension-128.png"
  },
  "permissions": ["storage", "activeTab", "identity", "alarms"],
  "host_permissions": ["https://bookmark-nav-sync.sarainosakura.workers.dev/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/extension-16.png",
      "32": "icons/extension-32.png",
      "48": "icons/extension-48.png",
      "128": "icons/extension-128.png"
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "bookmark-nav@sarainoq.local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["bookmarksInfo", "authenticationInfo"],
        "optional": []
      }
    }
  }
}
