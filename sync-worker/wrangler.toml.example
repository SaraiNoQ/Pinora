name = "bookmark-nav-sync"
main = "src/index.ts"
compatibility_date = "2026-05-08"

[[d1_databases]]
binding = "DB"
database_name = "bookmark_nav_sync"
database_id = "replace-with-your-d1-database-id"

[vars]
ALLOWED_EXTENSION_REDIRECT_ORIGINS = "http://localhost:3000,https://your-worker-subdomain.workers.dev"
ALLOWED_EXTENSION_ORIGINS = "http://localhost:3000"
SESSION_TTL_DAYS = "30"
